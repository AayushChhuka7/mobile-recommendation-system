generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OtpPurpose {
  Registration
  PasswordReset
  EmailChange
}

model Roles {
  roleId   String  @id @default(uuid()) @map("role_id") @db.Uuid
  roleName String  @unique @map("role_name") @db.VarChar(50)
  users    Users[]

  @@map("roles")
}

model Users {
  name       String
  userId     String  @id @default(uuid()) @map("user_id") @db.Uuid
  email      String  @unique @db.VarChar(255)
  password   String  @db.VarChar(255)
  phoneNo    String? @map("phone_no")
  isActive   Boolean @default(true) @map("is_active")
  isVerified Boolean @default(false) @map("is_verified")

  // Phase 1 RBAC: direct FK to Roles. Optional so existing rows can be
  // backfilled by the seed script without a schema-level DEFAULT.
  // (Phase 2 may need to migrate this to a join table when many-roles
  // or role→permission joins land; we'll handle that when we get there.)
  roleId String? @map("role_id") @db.Uuid
  role   Roles?  @relation(fields: [roleId], references: [roleId], onDelete: SetNull)

  otps Otp[]

  @@index([roleId])
  @@map("users")
}

model Otp {
  otpId     String     @id @default(uuid()) @map("otp_id") @db.Uuid
  code      String     @db.VarChar(6)
  userId    String     @map("user_id") @db.Uuid
  purpose   OtpPurpose @default(Registration) @map("purpose")
  expiresAt DateTime   @map("expires_at")
  isUsed    Boolean    @default(false) @map("is_used")
  createdAt DateTime   @default(now()) @map("created_at")

  user Users @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, purpose, isUsed, expiresAt])
  @@map("otps")
}
