# ─────────────────────────────────────────────────────────────────────────────
# Mobile Recommendation & Segmentation System — backend environment template
# Copy to backend/.env and fill in real values. NEVER commit the real .env.
# Generated: security remediation phase.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime mode. Affects cookie `secure` flag, error verbosity, etc.
NODE_ENV=development

# HTTP port the Express server binds to.
PORT=8000

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Pattern:
#   postgresql://<user>:<password>@<host>:<port>/<db>?schema=public
# For local development:
#   postgresql://postgres:password@localhost:5432/recommend?schema=public
# For production, use a managed provider (Neon, Supabase, RDS) and TLS:
#   postgresql://user:password@host:5432/db?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public

# ── Session signing ─────────────────────────────────────────────────────────
# Hex string, at least 32 bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=replace-with-a-64-character-hex-string

# ── SMTP (Nodemailer) — used for OTP delivery ───────────────────────────────
# For Gmail, create an "App password" at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password

# ── Frontend / CORS (consumed in a later phase) ─────────────────────────────
# Comma-separated list of allowed origins. Example for local dev:
#   http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000
