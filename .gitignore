# ─────────────────────────────────────────────────────────────────────────────
# Mobile Recommendation & Segmentation System — root .gitignore
# Applies to the whole monorepo (backend + frontend + ml + dataset).
# Per-package ignores live in backend/.gitignore, frontend/.gitignore, etc.
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets & local environment ─────────────────────────────────────────────
# Never commit real credentials, tokens, or connection strings.
# Use the matching .env.example to document required variables.
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Common editor / OS / tool state
.vscode/
.idea/
.DS_Store
Thumbs.db

# ── Node ────────────────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Build artefacts ─────────────────────────────────────────────────────────
/build
/dist
/coverage
/.next
/.out

# ── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Tooling caches ──────────────────────────────────────────────────────────
.eslintcache
.cache/
.parcel-cache/

# ── Prisma generated client (lives inside backend/src/generated) ────────────
# (also listed in backend/.gitignore; repeated here for clarity)

# ── Local data & uploads ────────────────────────────────────────────────────
uploads/
tmp/
*.local
